# Copy to .env and adjust. Loaded by docker-compose and Nuxt's runtimeConfig.

# Owner account, seeded on first launch (Feature #1).
NUXT_ADMIN_USERNAME=owner
NUXT_ADMIN_PASSWORD=change-me

# Secret for sealing the session cookie. Use a random 32+ char string.
NUXT_SESSION_PASSWORD=change-me-to-a-long-random-string

# SMTP. In dev these point at the Mailpit container.
NUXT_SMTP_HOST=mailpit
NUXT_SMTP_PORT=1025
