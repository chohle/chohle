# Copy to .env and adjust. Loaded by docker-compose and Nuxt's runtimeConfig.

# Owner account, seeded on first launch (Feature #1).
NUXT_ADMIN_USERNAME=owner
NUXT_ADMIN_PASSWORD=change-me

# Secret for sealing the session cookie. Use a random 32+ char string.
NUXT_SESSION_PASSWORD=change-me-to-a-long-random-string

# Public origin of this instance — used to build absolute URLs in emails (the
# hosted logo). For host/Docker dev use http://localhost:3000. In production
# it's derived from DOMAIN automatically; set it here only to override.
NUXT_SITE_URL=http://localhost:3000

# Encryption key for mailbox credentials (OAuth tokens, IMAP passwords).
# AES-256-GCM key is derived from this via SHA-256. Use a random 32+ char string.
# Rotating it invalidates every connected mailbox; reconnect after.
CHOHLE_SECRET=change-me-to-a-long-random-string

# Outbound email (SMTP). In Docker (the default), leave HOST/PORT unset here —
# docker-compose points the container at the Mailpit sidecar automatically
# (mailpit:1025) and everything lands in the Mailpit UI at http://localhost:8125.
# Only for host `yarn dev` (no Docker) do you uncomment the two localhost lines.
#
# To send REAL mail (invoices, quotes, replies) through a provider, fill in the
# four AUTH lines below. Full guide + troubleshooting: docs/SENDING_EMAIL.md
# NUXT_SMTP_HOST=localhost
# NUXT_SMTP_PORT=1125

# --- Real provider auth (leave commented for Mailpit) -------------------------
# Setting USER flips the app from the no-auth Mailpit relay to an authenticated
# provider: TLS is picked from the port and the From must be on the same domain
# as USER (the From-domain guard). Keep USER == the Billing sender address. Use
# the provider's SUBMISSION host/port, NOT the IMAP port 993 (465 = TLS, 587 =
# STARTTLS). See docs/SENDING_EMAIL.md for the example example and details.
# NUXT_SMTP_HOST=asmtp.mail.example.ch
# NUXT_SMTP_PORT=465
# NUXT_SMTP_USER=hello@chohle.ch
# NUXT_SMTP_PASS=
# NUXT_SMTP_SECURE=true   # escape hatch only — TLS is auto-derived from the port

# By default a connected IMAP host may not resolve to a loopback/private
# address (SSRF guard). Set to 1 only if you self-host your mail server on
# the LAN or in the same Docker network.
# IMAP_ALLOW_PRIVATE_HOSTS=1

# --- Demo mode -------------------------------------------------------------
# Give every visitor an isolated, seeded sandbox (no login, changes private,
# Reset button). Leave unset/false for the normal single-tenant app.
# CHOHLE_DEMO=true

# --- AI assistant (optional) -----------------------------------------------
# An in-app chatbot that can read your data and DRAFT new customers/invoices —
# every create needs your approval in the chat, and it can never edit or delete.
# Off unless CHOHLE_ASSISTANT=true. It talks to any OpenAI-compatible endpoint,
# so NUXT_LLM_BASE_URL can be the bundled Ollama (docker compose --profile llm),
# LM Studio, llama.cpp, vLLM, or a hosted API. See docs/ASSISTANT.md.
# Needs real RAM: an 8B model wants ~8 GB; on a small box use a 3B model or an
# external endpoint. Known-good tool-calling models: qwen2.5, llama3.1/3.2, mistral.
# CHOHLE_ASSISTANT=true
# NUXT_LLM_BASE_URL=http://ollama:11434/v1
# NUXT_LLM_MODEL=qwen2.5:7b
# NUXT_LLM_API_KEY=        # only for hosted endpoints that require a key

# --- Production deploy (docker-compose.prod.yml + Caddy) --------------------
# Domain Caddy gets an HTTPS certificate for and proxies to the app. Must
# already resolve to this server, with ports 80/443 open.
# DOMAIN=app.chohle.ch
